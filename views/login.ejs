<!DOCTYPE html>
<html lang="en">
<head>
    <title>Login - AstonCV</title>
    <link rel="stylesheet" href="/auth.css">
</head>
<body>

    <nav class="navbar">
        <a href="/" class="logo">AstonCV</a>
    </nav>

    <main class="auth-page">
        <div class="auth-card">
            <img src="/assets/aston_logo.jpeg" alt="Aston University" class="auth-logo">
            <div class="auth-header">
                <h1>Welcome Back</h1>
                <p class="auth-subtext">Log in to manage your CV and profile.</p>
            </div>

            <% if (error) { %>
                <p class="auth-error"><%= error %></p>
            <% } %>

            <form method="POST" action="/login" class="auth-form">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required>

                <label for="password">Password</label>
                <input type="password" id="password" name="password" required>

                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <button type="submit">Login</button>
            </form>

            <p class="auth-switch">
                Don’t have an account?
                <a href="/register">Register here</a>
            </p>
        </div>
    </main>

    <footer>
        <p>AstonCV © 2026</p>
        <p class="footer-subtext">Developed by Hasnain A</p>
    </footer>

</body>
</html>