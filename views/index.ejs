<!DOCTYPE html>
<html>
    <head>
        <title>AstonCV</title>
    </head>
    <body>
        <h1>AstonCV</h1>
        <% if (user) { %>
            <span>Welcome, <%= user.name %></span> |
            <a href="/edit">Edit my CV</a> |
            <a href="/logout">Logout</a>
        <% } else { %>
            <a href="/register">Register</a> |
            <a href="/login">Login</a>
        <% } %>

        <form method="GET" action="/" id="searchForm">
            <input type="text" name="search" id="searchInput" placeholder="Search by name or language" value="<%= search %>">
        </form>

        <h2> All CVs</h2>
            <ul id="cvList">
                <% cvs.forEach(cv => { %>
                <li>
                    <%= cv.name %> - <%= cv.email %> - <%= cv.language %>
                    <a href="/cv/<%= cv.id %>">View CV</a>
                </li>
            <% }) %>
            </ul>

        <script>
            const input = document.getElementById('searchInput');
            const list = document.getElementById('cvList');

            input.addEventListener('input', async () => {
                const res = await fetch(`/api/search?q=${encodeURIComponent(input.value)}`);
                const cvs = await res.json();
                list.innerHTML = cvs.map(cv =>
                    `<li><a href="/cv/${cv.id}">${cv.name}</a> — ${cv.email} — ${cv.language}</li>`
                ).join('');
            });
        </script>
    </body>
</html>