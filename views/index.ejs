<!DOCTYPE html>
<html lang="en">
<head>
    <title>AstonCV</title>
    <link rel="stylesheet" href="/index.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

    <!-- nav bar -->
    <nav class="navbar">
        <a href="/" class="logo">
            <span>AstonCV</span>
        </a>

        <% if (user) { %>
            <span class="nav-welcome">Welcome, <%= user.name %></span>
        <% } %>

        <div class="nav-links">
            <% if (user) { %>
                <a href="/edit" class="nav-icon-link">
                    <i class="fa-solid fa-pen-to-square"></i>
                    <span class="nav-tooltip">Edit My CV</span>
                </a>
                <a href="/logout" class="nav-icon-link">
                    <i class="fa-solid fa-right-from-bracket"></i>
                    <span class="nav-tooltip">Logout</span>
                </a>
            <% } else { %>
                <a href="/register" class="nav-btn">Register</a>
                <a href="/login">Login</a>
            <% } %>
        </div>
    </nav>

    <!-- hero -->
    <section class="hero">
        <div class="hero-content">
            <img src="/assets/aston_logo.jpeg" alt="Aston University" class="hero-logo">
            <h1>Discover Developer CVs from Aston University</h1>
            <p>Search and explore real developer CVs... or upload your own in minutes.</p>
        </div>

        <div class="search-wrapper">
            <input type="text" id="searchInput" placeholder="Search by name, language or bio..." aria-label="Search CVs">
            <i class="fa-solid fa-magnifying-glass search-icon"></i>
        </div>
    </section>

    <!-- cv cards -->
    <main class="container">
        <h2>Browse <%= cvs.length %> CVs</h2>

        <div id="cvList" class="cv-grid">
            <% cvs.forEach(cv => { %>
                <div class="cv-card">

                    <!-- header -->
                    <div class="card-header">
                        <h3><%= cv.name %></h3>
                        <p class="email"><i class="fa-solid fa-envelope"></i> <%= cv.email %></p>
                    </div>

                    <!-- bio -->
                    <% if (cv.bio) { %>
                        <p class="bio-preview">
                            <%= cv.bio.substring(0, 70) %><%= cv.bio.length > 70 ? '...' : '' %>
                        </p>
                    <% } %>

                    <!-- footer -->
                    <div class="card-footer">
                        <% if (cv.language) { %>
                            <span class="tag"><i class="fa-solid fa-code"></i> <%= cv.language %></span>
                        <% } %>

                        <a href="/cv/<%= cv.id %>" class="view-btn">
                            <i class="fa-solid fa-arrow-up-right-from-square"></i>&nbsp;&nbsp;View CV
                        </a>
                    </div>

                </div>
            <% }) %>
        </div>
    </main>

    <!-- footer -->
    <footer>
        <p>AstonCV © 2026</p>
        <p class="footer-subtext">Developed by Hasnain A</p>
    </footer>

    <script src="/index.js"></script>

</body>
</html>