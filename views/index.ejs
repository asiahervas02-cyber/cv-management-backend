<!DOCTYPE html>
<html lang="en">
<head>
    <title>AstonCV</title>
    <link rel="stylesheet" href="/index.css">
</head>
<body>

    <!-- nav bar -->
    <nav class="navbar">
        <a href="/" class="logo">
            <span>AstonCV</span>
        </a>

        <div class="nav-links">
            <% if (user) { %>
                <span>Welcome, <%= user.name %></span>
                <a href="/edit">Edit my CV</a>
                <a href="/logout">Logout</a>
            <% } else { %>
                <a href="/register" class="nav-btn">Register</a>
                <a href="/login">Login</a>
            <% } %>
        </div>
    </nav>

    <!-- hero -->
    <section class="hero">
        <div class="hero-content">
            <img src="assets/aston_logo.jpeg" alt="Aston University" class="hero-logo">
            <h1>Discover Developer CVs from Aston University</h1>
            <p>Search and explore real developer CVs... or upload your own in minutes.</p>
        </div>

        <input type="text" id="searchInput" placeholder="Search by name, language or bio..." aria-label="Search CVs">
    </section>

    <!-- cv cards -->
    <main class="container">
        <h2>Browse <%= cvs.length %> CVs</h2>

        <div id="cvList" class="cv-grid">
            <% cvs.forEach(cv => { %>
                <div class="cv-card">

                    <!-- Header -->
                    <div class="card-header">
                        <h3><%= cv.name %></h3>
                        <p class="email"><%= cv.email %></p>
                    </div>

                    <!-- Bio Preview -->
                    <% if (cv.bio) { %>
                        <p class="bio-preview">
                            <%= cv.bio.substring(0, 70) %><%= cv.bio.length > 70 ? '...' : '' %>
                        </p>
                    <% } %>

                    <!-- Footer (Tag + Button) -->
                    <div class="card-footer">
                        <% if (cv.language) { %>
                            <span class="tag"><%= cv.language %></span>
                        <% } %>

                        <a href="/cv/<%= cv.id %>" class="view-btn">View CV</a>
                    </div>

                </div>
            <% }) %>
        </div>
    </main>

    <!-- footer -->
    <footer>
        <p>AstonCV © 2026</p>
        <p class="footer-subtext">Developed by Hasnain A</p>
    </footer>

    <script src="/index.js"></script>

</body>
</html>